      "units": [
        {
          "id": "u1",
          "title": "Basics",
          "subtitle": "People, food and your first words",
          "tip": "Korean word order is Subject-Object-Verb (SOV), so the verb comes last. The topic particle 은/는 marks what the sentence is about (은 after a consonant, 는 after a vowel). The copula 'to be' is 이에요 after a consonant and 예요 after a vowel: 남자예요 (it's a man), 빵이에요 (it's bread).",
          "words": [
            { "es": "남자", "en": "man", "rom": "namja", "emoji": "👨" },
            { "es": "여자", "en": "woman", "rom": "yeoja", "emoji": "👩" },
            { "es": "남자아이", "en": "boy", "rom": "namjaai", "emoji": "👦" },
            { "es": "여자아이", "en": "girl", "rom": "yeojaai", "emoji": "👧" },
            { "es": "물", "en": "water", "rom": "mul", "emoji": "💧" },
            { "es": "빵", "en": "bread", "rom": "ppang", "emoji": "🍞" },
            { "es": "사과", "en": "apple", "rom": "sagwa", "emoji": "🍎" },
            { "es": "우유", "en": "milk", "rom": "uyu", "emoji": "🥛" },
            { "es": "저", "en": "I / me", "rom": "jeo" },
            { "es": "당신", "en": "you", "rom": "dangsin" },
            { "es": "네", "en": "yes", "rom": "ne" },
            { "es": "아니요", "en": "no", "rom": "aniyo" }
          ],
          "sentences": [
            { "es": "저는 남자예요.", "en": "I am a man.", "rom": "jeoneun namjayeyo.", "altEn": ["I'm a man."] },
            { "es": "저는 여자예요.", "en": "I am a woman.", "rom": "jeoneun yeojayeyo.", "altEn": ["I'm a woman."] },
            { "es": "이건 물이에요.", "en": "This is water.", "rom": "igeon murieyo.", "altEn": ["This is the water.", "It is water."] },
            { "es": "이건 빵이에요.", "en": "This is bread.", "rom": "igeon ppangieyo.", "altEn": ["It is bread."] },
            { "es": "남자아이가 사과를 먹어요.", "en": "The boy eats an apple.", "rom": "namjaaiga sagwareul meogeoyo.", "altEn": ["The boy is eating an apple."] },
            { "es": "여자아이가 우유를 마셔요.", "en": "The girl drinks milk.", "rom": "yeojaaiga uyureul masyeoyo.", "altEn": ["The girl is drinking milk."] },
            { "es": "네, 저는 여자예요.", "en": "Yes, I am a woman.", "rom": "ne, jeoneun yeojayeyo.", "altEn": ["Yes, I'm a woman."] },
