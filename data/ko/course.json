            { "es": "여자가 빵을 먹어요.", "en": "The woman eats bread.", "rom": "yeojaga ppangeul meogeoyo.", "altEn": ["The woman is eating bread."] }
          ]
        },
        {
          "id": "u2",
          "title": "Greetings",
          "subtitle": "Say hello, thank you and goodbye",
          "tip": "The polite ending -요 makes speech friendly but polite, and it is what beginners should use. 안녕하세요 works for both 'hello' and casual greetings. When parting, the person leaving hears 안녕히 계세요 (stay well) and the person staying hears 안녕히 가세요 (go well).",
          "words": [
            { "es": "안녕하세요", "en": "hello", "rom": "annyeonghaseyo" },
            { "es": "안녕히 가세요", "en": "goodbye (to one leaving)", "rom": "annyeonghi gaseyo" },
            { "es": "안녕히 계세요", "en": "goodbye (to one staying)", "rom": "annyeonghi gyeseyo" },
            { "es": "감사합니다", "en": "thank you", "rom": "gamsahamnida" },
            { "es": "고마워요", "en": "thanks", "rom": "gomawoyo" },
            { "es": "안녕히 주무세요", "en": "good night", "rom": "annyeonghi jumuseyo" },
            { "es": "괜찮아요", "en": "I'm fine / it's okay", "rom": "gwaenchanayo" },
            { "es": "이름", "en": "name", "rom": "ireum" },
            { "es": "반가워요", "en": "nice to meet you", "rom": "bangawoyo" },
